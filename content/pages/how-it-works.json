        "heading": "Need Help Getting Started?",
        "body": "<div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: var(--space-lg);\">\n    <div>\n        <h3 class=\"mb-sm\">Resources</h3>\n        <p class=\"mb-md\">Access templates, guides, and tools to help you succeed.</p>\n        <a href=\"resources.html\" class=\"btn btn-outline\">View Resources</a>\n    </div>\n    <div>\n        <h3 class=\"mb-sm\">Support Services</h3>\n        <p class=\"mb-md\">Learn about available support services and training programs.</p>\n        <a href=\"support-services.html\" class=\"btn btn-outline\">Learn More</a>\n    </div>\n    <div>\n        <h3 class=\"mb-sm\">Contact Us</h3>\n        <p class=\"mb-md\">Have questions? Our team is here to help.</p>\n        <a href=\"contact.html\" class=\"btn btn-outline\">Get in Touch</a>\n    </div>\n</div>"
      }
